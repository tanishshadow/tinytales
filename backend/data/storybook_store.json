  "stories": [
    {
      "id": "940fd5ac0a6347aa",
      "title": "The Little One and the Wobbly String",
      "child_name": "the little one",
      "original_prompt": "string",
      "tone": "gentle",
      "pages": [
        {
          "page_number": 1,
          "text": "The little one felt a wobbly feeling, like a loose string inside their tummy. It made them feel a little bit worried, like a kite with a tangled tail.",
          "mood": "worried"
        },
        {
          "page_number": 2,
          "text": "One night, a friendly Moonbeam tiptoed into the little one's room. \"That wobbly string is just your feelings dancing,\" it whispered, \"and we can help them dance a happy tune!\"",
          "mood": "magical"
        },
        {
          "page_number": 3,
          "text": "The Moonbeam showed the little one how to find the Silly String Sprites. They were tiny, giggling creatures who loved to twist and twirl all the feelings away.",
          "mood": "playful"
        },
        {
          "page_number": 4,
          "text": "The little one took a deep breath, imagining the Silly String Sprites tickling the wobbly feeling. They giggled and wiggled, making the string dance itself into a happy knot.",
          "mood": "brave"
        },
        {
          "page_number": 5,
          "text": "The wobbly feeling smoothed out, leaving a warm, cozy hum. The little one snuggled down, safe and sound, with happy dreams dancing in their sleep.",
          "mood": "cozy"
        }
      ],
      "created_at": "2026-04-22T20:10:37.273740+00:00",
      "updated_at": "2026-04-22T20:10:37.273776+00:00",
